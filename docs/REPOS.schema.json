{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/RedRock-Constitution/blob/main/docs/REPOS.schema.json",
  "title": "RedRock Repositories Registry Schema",
  "description": "Machine-readable schema for cross-repository navigation and governance metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "repos"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^RR-REPOS-[0-9]+\\.[0-9]+$",
      "examples": [
        "RR-REPOS-1.0"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repo"
      }
    }
  },
  "$defs": {
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_name",
        "repo_url",
        "positioning_cn",
        "positioning_en",
        "standards_entry",
        "demo_entry"
      ],
      "properties": {
        "repo_name": {
          "type": "string",
          "minLength": 1
        },
        "repo_url": {
          "type": "string",
          "format": "uri"
        },
        "positioning_cn": {
          "type": "string",
          "minLength": 1
        },
        "positioning_en": {
          "type": "string",
          "minLength": 1
        },
        "standards_entry": {
          "$ref": "#/$defs/linkOrPath"
        },
        "demo_entry": {
          "$ref": "#/$defs/linkOrPath"
        },
        "standard_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "linkOrPath": {
      "type": "string",
      "minLength": 1
    }
  }
}
